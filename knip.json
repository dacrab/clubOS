{
	"$schema": "https://unpkg.com/knip@latest/schema.json",
	"entry": [
		"src/**/*.{svelte,ts}",
		"scripts/**/*.ts"
	],
	"project": [
		"src/**/*.{ts,svelte}",
		"scripts/**/*.ts"
	],
	"ignoreDependencies": [
		"tailwindcss-animate",
		"tailwindcss"
	],
	"ignore": [],
	"paths": {
		"$lib/*": [
			"src/lib/*"
		],
		"$app/*": [
			".svelte-kit/types/app/*"
		],
		"$env/*": [
			".svelte-kit/ambient.d.ts"
		]
	},
	"ignoreUnresolved": []
}
