{
	"name": "clubos-svelte",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json && knip && eslint .",
		"check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"test": "SKIP_DB_TESTS=true vitest run",
		"test:db": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"db:seed": "bun scripts/seed.ts",
		"db:reset": "supabase db reset && bun scripts/seed.ts"
	},
	"devDependencies": {
		"@eslint/js": "^10",
		"@internationalized/date": "^3.12.0",
		"@lucide/svelte": "^0.577.0",
		"@playwright/test": "^1.58.2",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.2.1",
		"@types/node": "^25.5.0",
		"@vitest/coverage-v8": "^4.1.0",
		"@vitest/eslint-plugin": "^1.6.12",
		"bits-ui": "^2.16.3",
		"clsx": "^2.1.1",
		"eslint": "^10",
		"eslint-plugin-svelte": "^3.15.2",
		"globals": "^17.4.0",
		"jsdom": "^28.1.0",
		"knip": "^5.86.0",
		"svelte": "^5.53.12",
		"svelte-check": "^4.4.5",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "^4.2.1",
		"tailwindcss-animate": "^1.0.7",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.0",
		"vite": "^7.3.1",
		"vitest": "^4.1.0"
	},
	"dependencies": {
		"@supabase/ssr": "^0.9.0",
		"@supabase/supabase-js": "^2.99.1",
		"@vercel/analytics": "^2.0.1",
		"svelte-sonner": "^1.1.0"
	},
	"overrides": {
		"cookie": ">=0.7.0"
	}
}
