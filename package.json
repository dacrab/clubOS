		"@vitest/coverage-v8": "^4.1.8",
		"jsdom": "^29.1.1",
		"knip": "^6.16.1",
		"svelte": "^5.56.2",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.0",
		"tailwindcss-animate": "^1.0.7",
