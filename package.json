{
	"name": "clubos-svelte",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json && knip && eslint .",
		"check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"test": "SKIP_DB_TESTS=true vitest run",
		"test:db": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"db:seed": "bun scripts/seed.ts",
		"db:reset": "supabase db reset && bun scripts/seed.ts"
	},
	"devDependencies": {
		"@eslint/js": "^10",
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.57.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^25.6.0",
		"@vitest/coverage-v8": "^4.1.4",
		"@vitest/eslint-plugin": "^1.6.15",
		"eslint": "^10",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"jsdom": "^29.0.2",
		"knip": "^6.4.0",
		"svelte": "^5.55.3",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"tailwindcss-animate": "^1.0.7",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.8",
		"vitest": "^4.1.4"
	},
	"dependencies": {
		"@internationalized/date": "^3.12.0",
		"@lucide/svelte": "^0.577.0",
		"@supabase/ssr": "^0.10.2",
		"@supabase/supabase-js": "^2.103.0",
		"@vercel/analytics": "^2.0.1",
		"bits-ui": "^2.17.3",
		"svelte-sonner": "^1.1.0",
		"tailwind-merge": "^3.5.0",
		"tsx": "^4.21.0"
	},
	"overrides": {
		"cookie": ">=0.7.0"
	}
}
