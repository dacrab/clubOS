		"@tailwindcss/vite": "^4.3.2",
		"@types/node": "^26.1.1",
		"@vitest/coverage-v8": "^4.1.10",
		"jsdom": "^29.1.1",
		"knip": "^6.25.0",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.2",
		"tailwindcss": "^4.3.2",
		"tailwindcss-animate": "^1.0.7",
